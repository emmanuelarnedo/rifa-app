{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "index.html",  "use": "@vercel/static" },
    { "src": "admin.html",  "use": "@vercel/static" },
    { "src": "css/**",      "use": "@vercel/static" },
    { "src": "js/**",       "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/env",    "dest": "/api/env.js" },
    { "src": "/(.*)",       "dest": "/$1" }
  ]
}
